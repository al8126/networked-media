</head>
  <div class="page">
<body>
  <nav class="navbar">
    <div class="navbar__logo">
      <a href="/">DROODLING</a>
    </div>
    <ul class="navbar__links">
      <li><a href="/about">ABOUT</a></li>
      <li><a href="/submit">SUBMIT</a></li>
      <li><a href="/game">GAME</a></li>
    </ul>
